---
import type { Activity } from "../data/itinerary";

interface Props {
  activity: Activity;
  area?: string;
}

const { activity, area = "" } = Astro.props;

function mapsUrl(name: string): string {
  const query = encodeURIComponent(`${name} ${area} Japan`.trim());
  return `https://maps.google.com/maps?q=${query}`;
}

function directionsUrl(name: string): string {
  const dest = encodeURIComponent(`${name} ${area} Japan`.trim());
  return `https://www.google.com/maps/dir/?api=1&destination=${dest}`;
}

const isPlace = activity.saved || activity.isNew;
const cat = activity.cat;
const hasTransit = activity.transit && activity.transit.length > 0;

const lineColors: Record<string, string> = {
  "Yamanote": "#9ACD32", "Saikyō": "#00B261", "Keihin-Tōhoku": "#00B2E5",
  "Takasaki": "#F68B1E", "Utsunomiya": "#F68B1E", "Chūō-Sōbu": "#FFD400",
  "Chūō": "#F15A22", "Yokosuka": "#0068B7", "Shonan-Shinjuku": "#E21F26",
  "Keiyō": "#C9242F", "Kawagoe": "#8B8B00", "Skyliner": "#003894",
  "Keisei": "#003894", "Tōyoko": "#DA0442", "Ōimachi": "#F18C43",
  "Den-en-toshi": "#00A23B", "TOBU": "#0F1E72", "Rinkai": "#00A4DB",
  "Odakyu": "#1E90FF", "Ōedo": "#B6007A", "Ginza": "#FF9500",
  "Marunouchi": "#F62E36", "Hibiya": "#B5B5AC", "Tōzai": "#009BBF",
  "Chiyoda": "#00A650", "Yūrakuchō": "#C1A470", "Hanzōmon": "#8B76D0",
  "Namboku": "#00ADA0", "Fukutoshin": "#9C5E31", "Andando": "#9CA3AF",
};

function getLineColor(name: string): string {
  for (const [key, color] of Object.entries(lineColors)) {
    if (name.includes(key)) return color;
  }
  return "#71717A";
}

function shortLine(name: string): string {
  return name.replace(/^JR /, "").replace(/^Metro /, "").replace(/^Keisei /, "");}


const catConfig = {
  food:       { emoji: "🍜", badge: "Restaurante", nameClass: "text-orange-700 dark:text-orange-300 hover:text-orange-500 dark:hover:text-orange-400", badgeClass: "bg-orange-100 text-orange-700 dark:bg-orange-900/50 dark:text-orange-300" },
  temple:     { emoji: "⛩️", badge: "Templo",      nameClass: "text-red-700 dark:text-red-300 hover:text-red-500 dark:hover:text-red-400",             badgeClass: "bg-red-100 text-red-700 dark:bg-red-900/50 dark:text-red-300" },
  attraction: { emoji: "📍", badge: "Visita",      nameClass: "text-sky-700 dark:text-sky-300 hover:text-sky-500 dark:hover:text-sky-400",             badgeClass: "bg-sky-100 text-sky-700 dark:bg-sky-900/50 dark:text-sky-300" },
} as const;

const cfg = cat ? catConfig[cat] : null;
---

<li class="py-2">
  <div class="flex items-start gap-2">
    {hasTransit ? (
      <span class="mt-0.5 shrink-0 text-sm leading-none">🚃</span>
    ) : cfg ? (
      <span class="mt-0.5 shrink-0 text-sm leading-none">{cfg.emoji}</span>
    ) : (
      <span class="mt-1.5 shrink-0 w-1.5 h-1.5 rounded-full bg-zinc-300 dark:bg-zinc-600"></span>
    )}
    <div class="flex-1 min-w-0">
      <div class="flex items-start justify-between gap-2">
        <div class="flex flex-wrap items-center gap-1.5 min-w-0">
          {isPlace ? (
            <a href={mapsUrl(activity.name)} target="_blank" rel="noopener noreferrer" class:list={[
              "font-medium text-sm inline-flex items-center gap-1 transition-colors",
              cfg ? cfg.nameClass : "text-zinc-900 dark:text-zinc-100 hover:text-blue-600 dark:hover:text-blue-400",
            ]}>
              {activity.name}
              <svg class="w-3 h-3 text-blue-500 dark:text-blue-400 shrink-0" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/></svg>
            </a>
          ) : (
            <span class:list={[
              "font-medium text-sm",
              cfg ? cfg.nameClass.split(" hover:")[0] : "",
            ]}>{activity.name}</span>
          )}
          {activity.isNew && (
            <span class="shrink-0 w-1.5 h-1.5 rounded-full bg-amber-400 dark:bg-amber-500" title="Nuevo"></span>
          )}
          {activity.cost && (
            <span class:list={[
              "inline-flex items-center px-1.5 py-0.5 rounded text-[0.65rem] font-bold",
              activity.cost === "GRATIS" || activity.cost.includes("GRATIS")
                ? "bg-emerald-100 text-emerald-700 dark:bg-emerald-900/50 dark:text-emerald-300"
                : "bg-zinc-100 text-zinc-600 dark:bg-zinc-800 dark:text-zinc-400",
            ]}>
              {activity.cost}
            </span>
          )}
        </div>
        {isPlace && (
          <a href={directionsUrl(activity.name)} target="_blank" rel="noopener noreferrer" class="shrink-0 w-7 h-7 rounded-full flex items-center justify-center hover:bg-zinc-100 dark:hover:bg-zinc-800 transition-colors" title="Como llegar">
            <svg class="w-3.5 h-3.5 text-zinc-400 dark:text-zinc-500 hover:text-blue-500 dark:hover:text-blue-400 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7" /></svg>
          </a>
        )}
      </div>
      {activity.description && (
        <p class="text-xs text-zinc-500 dark:text-zinc-400 mt-0.5 leading-relaxed">{activity.description}</p>
      )}
      {hasTransit && (
        <div class="mt-1.5 ml-0.5">
          {activity.transit!.map((t, i) => {
            const color = getLineColor(t.line);
            const isFirst = i === 0;
            const isLast = i === activity.transit!.length - 1;
            const walking = t.line.toLowerCase().includes("andando");
            const nextColor = !isLast ? getLineColor(activity.transit![i + 1].line) : null;
            return (
              <>
                {/* Estacion */}
                <div class="flex items-center gap-2">
                  {isFirst ? (
                    <span class="transit-dot w-2.5 h-2.5 rounded-full border-2 shrink-0 relative z-10" style={`border-color: ${color}`} />
                  ) : (
                    <span class="w-2.5 h-2.5 rounded-full shrink-0 relative z-10 flex items-center justify-center" style={`background: ${color}; outline: 2px solid ${nextColor || color}; outline-offset: 1px;`}>
                      <span class="w-1 h-1 rounded-full bg-white"></span>
                    </span>
                  )}
                  <div class="flex items-center gap-1.5">
                    <span class="text-[0.65rem] font-bold text-zinc-700 dark:text-zinc-300">{t.from}</span>
                    <span class:list={[
                      "text-[0.65rem] font-bold uppercase tracking-wider",
                      isFirst ? "text-emerald-600 dark:text-emerald-400" : "text-amber-600 dark:text-amber-400",
                    ]}>
                      {isFirst ? (walking ? "inicio" : "subir") : (walking ? "caminar" : "transbordo")}
                    </span>
                  </div>
                </div>
                {/* Linea vertical + badge */}
                <div class="flex gap-2">
                  <div class="flex justify-center w-2.5 shrink-0">
                    {walking ? (
                      <div class="w-[2px] h-5 border-l-[2px] border-dashed" style={`border-color: ${color}`}></div>
                    ) : (
                      <div class="w-[2px] h-5 rounded-full" style={`background: ${color}`}></div>
                    )}
                  </div>
                  <div class="flex items-center gap-1.5 py-0.5">
                    {walking ? (
                      <span class="text-[0.65rem] font-semibold px-1.5 py-0.5 rounded-full bg-zinc-200 dark:bg-zinc-700 text-zinc-600 dark:text-zinc-300">🚶 Andando</span>
                    ) : (
                      <span class="text-[0.65rem] font-semibold px-1.5 py-0.5 rounded-full whitespace-nowrap" style={`background: ${color}; color: white`}>{shortLine(t.line)}</span>
                    )}
                  </div>
                </div>
                {/* Estacion destino final */}
                {isLast && (
                  <div class="flex items-center gap-2">
                    <span class="w-2.5 h-2.5 rounded-full shrink-0 relative z-10" style={`background: ${color}`} />
                    <div class="flex items-center gap-1.5">
                      <span class="text-[0.65rem] font-bold text-red-600 dark:text-red-400">{t.to}</span>
                      <span class="text-[0.65rem] font-bold uppercase tracking-wider text-red-500 dark:text-red-400">
                        {walking ? "destino" : "bajar"}
                      </span>
                    </div>
                  </div>
                )}
              </>
            );
          })}
        </div>
      )}
      {activity.tips && activity.tips.length > 0 && (
        <ul class="mt-1 space-y-0.5">
          {activity.tips.map((tip) => (
            <li class="text-xs text-amber-600 dark:text-amber-400 flex items-start gap-1">
              <span class="shrink-0">*</span>
              <span>{tip}</span>
            </li>
          ))}
        </ul>
      )}
      {activity.subItems && activity.subItems.length > 0 && (
        <ul class="mt-1.5 ml-2 space-y-1 border-l-2 border-zinc-200 dark:border-zinc-700 pl-3">
          {activity.subItems.map((sub) => (
            <li class="text-xs">
              <div class="flex items-start justify-between gap-1">
                <div class="flex flex-wrap items-center gap-1 min-w-0">
                  {(sub.saved || sub.isNew) ? (
                    <a href={mapsUrl(sub.name)} target="_blank" rel="noopener noreferrer" class="text-zinc-700 dark:text-zinc-300 inline-flex items-center gap-1 hover:text-blue-600 dark:hover:text-blue-400 transition-colors">
                      {sub.name}
                      <svg class="w-2.5 h-2.5 text-blue-500 dark:text-blue-400 shrink-0" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/></svg>
                    </a>
                  ) : (
                    <span class="text-zinc-700 dark:text-zinc-300">{sub.name}</span>
                  )}
                  {sub.isNew && (
                    <span class="shrink-0 w-1.5 h-1.5 rounded-full bg-amber-400 dark:bg-amber-500" title="Nuevo"></span>
                  )}
                  {sub.cost && (
                    <span class:list={[
                      "px-1 py-0.5 rounded text-[0.65rem] font-bold",
                      sub.cost === "GRATIS" ? "bg-emerald-100 text-emerald-700 dark:bg-emerald-900/50 dark:text-emerald-300" : "bg-zinc-100 text-zinc-600 dark:bg-zinc-800 dark:text-zinc-400",
                    ]}>{sub.cost}</span>
                  )}
                </div>
                {(sub.saved || sub.isNew) && (
                  <a href={directionsUrl(sub.name)} target="_blank" rel="noopener noreferrer" class="shrink-0 w-5 h-5 rounded-full flex items-center justify-center hover:bg-zinc-100 dark:hover:bg-zinc-800 transition-colors" title="Como llegar">
                    <svg class="w-2.5 h-2.5 text-zinc-400 dark:text-zinc-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7" /></svg>
                  </a>
                )}
              </div>
              {sub.description && <p class="text-zinc-500 dark:text-zinc-400 mt-0.5">{sub.description}</p>}
            </li>
          ))}
        </ul>
      )}
    </div>
  </div>
</li>

<style>
  .transit-dot {
    background: white;
  }
  :global(.dark) .transit-dot {
    background: rgb(24 24 27);
  }
</style>
