---
import type { TimeSlot } from "../data/itinerary";
import ActivityItem from "./ActivityItem.astro";

interface Props {
  slot: TimeSlot;
  area?: string;
}

const { slot, area = "" } = Astro.props;

const iconMap: Record<string, { emoji: string; gradient: string }> = {
  sun: { emoji: "morning", gradient: "from-amber-400 to-orange-400" },
  sunset: { emoji: "afternoon", gradient: "from-orange-400 to-rose-400" },
  moon: { emoji: "night", gradient: "from-indigo-500 to-purple-500" },
};

const style = iconMap[slot.icon] || iconMap.sun;
---

<section class="bg-white dark:bg-zinc-900 rounded-2xl shadow-sm border border-zinc-100 dark:border-zinc-800 overflow-hidden">
  <div class={`bg-gradient-to-r ${style.gradient} px-4 py-2.5 flex items-center justify-between`}>
    <h3 class="text-white font-semibold text-sm">{slot.label}</h3>
    <span class="text-white/80 text-xs">{slot.timeRange}</span>
  </div>
  <ul class="px-4 py-2 divide-y divide-zinc-50 dark:divide-zinc-800/50">
    {slot.activities.map((activity) => (
      <ActivityItem activity={activity} area={area} />
    ))}
  </ul>
</section>
