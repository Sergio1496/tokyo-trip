---
interface Props {
  title: string;
  activeNav?: "home" | "days" | "transport" | "budget" | "places" | "random" | "discover";
}

const { title, activeNav = "home" } = Astro.props;
import "../styles/global.css";
import ChatWidget from "../components/ChatWidget.astro";
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#1e1b4b" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} | Tokyo 2026</title>
  </head>
  <body class="bg-zinc-50 text-zinc-800 dark:bg-zinc-950 dark:text-zinc-100 pb-20 min-h-screen font-sans antialiased">
    <!-- Login overlay -->
    <div id="login-overlay" class="fixed inset-0 z-[100] bg-zinc-950 flex items-center justify-center p-6" style="display:none;">
      <div class="w-full max-w-xs space-y-6 text-center">
        <div>
          <span class="text-5xl">🗼</span>
          <h1 class="text-2xl font-bold text-white mt-3">Tokyo 2026</h1>
          <p class="text-zinc-400 text-sm mt-1">Introduce tus credenciales</p>
        </div>
        <form id="login-form" class="space-y-3">
          <input
            id="login-user"
            type="text"
            placeholder="Usuario"
            autocomplete="username"
            class="w-full px-4 py-3 rounded-xl bg-zinc-800 border border-zinc-700 text-white placeholder-zinc-500 focus:outline-none focus:border-red-500 transition-colors text-sm"
          />
          <input
            id="login-pass"
            type="password"
            placeholder="Contraseña"
            autocomplete="current-password"
            class="w-full px-4 py-3 rounded-xl bg-zinc-800 border border-zinc-700 text-white placeholder-zinc-500 focus:outline-none focus:border-red-500 transition-colors text-sm"
          />
          <p id="login-error" class="text-red-400 text-xs hidden">Usuario o contraseña incorrectos</p>
          <button
            type="submit"
            class="w-full bg-red-500 hover:bg-red-400 text-white font-bold py-3 rounded-xl text-sm active:scale-95 transition-all"
          >
            Entrar
          </button>
        </form>
      </div>
    </div>

    <slot />

    <ChatWidget />

    <!-- Bottom Navigation -->
    <nav class="fixed bottom-0 left-0 right-0 bg-white dark:bg-zinc-900 border-t border-zinc-200 dark:border-zinc-800 z-50 safe-area-bottom">
      <div class="flex justify-around items-center h-16 max-w-lg mx-auto">
        <a href="/" class:list={["flex flex-col items-center gap-0.5 text-xs", activeNav === "home" ? "text-red-500" : "text-zinc-400 dark:text-zinc-500"]}>
          <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" /></svg>
          <span>Inicio</span>
        </a>
        <a href="/dia/1" class:list={["flex flex-col items-center gap-0.5 text-xs", activeNav === "days" ? "text-red-500" : "text-zinc-400 dark:text-zinc-500"]}>
          <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>
          <span>Dias</span>
        </a>
        <a href="/transporte" class:list={["flex flex-col items-center gap-0.5 text-xs", activeNav === "transport" ? "text-red-500" : "text-zinc-400 dark:text-zinc-500"]}>
          <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>
          <span>Transporte</span>
        </a>
        <a href="/random" class:list={["flex flex-col items-center gap-0.5 text-xs", (activeNav === "random" || activeNav === "discover" || activeNav === "places") ? "text-red-500" : "text-zinc-400 dark:text-zinc-500"]}>
          <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg>
          <span>Descubrir</span>
        </a>
        <a href="/presupuesto" class:list={["flex flex-col items-center gap-0.5 text-xs", activeNav === "budget" ? "text-red-500" : "text-zinc-400 dark:text-zinc-500"]}>
          <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
          <span>Ahorro</span>
        </a>
      </div>
    </nav>

    <script>
      // Auth gate
      const AUTH_KEY = "tokyo26_auth";
      const overlay = document.getElementById("login-overlay")!;
      const mainContent = document.querySelector("body > :not(#login-overlay):not(nav):not(script):not(style)") as HTMLElement;

      if (localStorage.getItem(AUTH_KEY) !== "ok") {
        overlay.style.display = "";
        document.body.style.overflow = "hidden";
        document.querySelectorAll<HTMLElement>("body > :not(#login-overlay)").forEach(el => {
          if (el.tagName !== "SCRIPT" && el.tagName !== "STYLE") el.style.display = "none";
        });

        document.getElementById("login-form")!.addEventListener("submit", (e) => {
          e.preventDefault();
          const user = (document.getElementById("login-user") as HTMLInputElement).value;
          const pass = (document.getElementById("login-pass") as HTMLInputElement).value;

          if (user === "claude" && pass === "q1w2e3") {
            localStorage.setItem(AUTH_KEY, "ok");
            location.reload();
          } else {
            document.getElementById("login-error")!.classList.remove("hidden");
            (document.getElementById("login-pass") as HTMLInputElement).value = "";
          }
        });
      } else {
        overlay.remove();
      }

      // "Hoy" detection
      const tripStart = new Date(2026, 4, 3);
      const today = new Date();
      const diffDays = Math.floor((today.getTime() - tripStart.getTime()) / (1000 * 60 * 60 * 24)) + 1;
      if (diffDays >= 1 && diffDays <= 14) {
        document.documentElement.dataset.todayDay = String(diffDays);
      }
    </script>

    <style>
      .safe-area-bottom {
        padding-bottom: env(safe-area-inset-bottom, 0px);
      }
    </style>
  </body>
</html>
