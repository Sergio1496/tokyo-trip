---
import Layout from "../../layouts/Layout.astro";
import DayNav from "../../components/DayNav.astro";
import TimeSlotCard from "../../components/TimeSlotCard.astro";
import FlightCard from "../../components/FlightCard.astro";
import RouteChain from "../../components/RouteChain.astro";
import RouteMap from "../../components/RouteMap.astro";
import ActivityItem from "../../components/ActivityItem.astro";
import { days } from "../../data/itinerary";

export function getStaticPaths() {
  return days.map((day) => ({
    params: { day: String(day.dayNumber) },
    props: { day },
  }));
}

const { day } = Astro.props;
const prevDay = day.dayNumber > 1 ? day.dayNumber - 1 : null;
const nextDay = day.dayNumber < 14 ? day.dayNumber + 1 : null;
---

<Layout title={`Dia ${day.dayNumber} - ${day.title}`} activeNav="days">
  <DayNav currentDay={day.dayNumber} />

  <main class="max-w-lg mx-auto px-4 py-4 space-y-4">
    <!-- Day Header -->
    <div class="text-center">
      <div class="inline-flex items-center gap-2 bg-red-50 dark:bg-red-950 text-red-600 dark:text-red-400 px-3 py-1 rounded-full text-xs font-semibold mb-2">
        <span>Dia {day.dayNumber}</span>
        <span class="w-1 h-1 rounded-full bg-red-300 dark:bg-red-700"></span>
        <span>{day.weekday} {day.date}</span>
      </div>
      <h1 class="text-2xl font-bold text-zinc-900 dark:text-white">{day.title}</h1>
      <p class="text-sm text-zinc-500 dark:text-zinc-400 mt-1">{day.subtitle}</p>
      <div class="mt-2 inline-flex items-center gap-1 text-xs text-zinc-400 dark:text-zinc-500 bg-zinc-100 dark:bg-zinc-800 px-2.5 py-1 rounded-full">
        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
        <span>{day.area}</span>
      </div>
    </div>

    <!-- Weather -->
    <div id="weather-skeleton" class="bg-white dark:bg-zinc-900 rounded-2xl border border-zinc-100 dark:border-zinc-800 p-3">
      <div class="flex items-center gap-2 animate-pulse">
        <div class="w-8 h-8 rounded-lg bg-zinc-200 dark:bg-zinc-700"></div>
        <div class="flex-1 space-y-1.5">
          <div class="h-3.5 w-24 bg-zinc-200 dark:bg-zinc-700 rounded"></div>
          <div class="h-3 w-32 bg-zinc-100 dark:bg-zinc-800 rounded"></div>
        </div>
      </div>
    </div>
    <div id="weather" class="hidden bg-white dark:bg-zinc-900 rounded-2xl border border-zinc-100 dark:border-zinc-800 p-3">
      <div class="flex items-center justify-between">
        <div class="flex items-center gap-2">
          <span id="w-emoji" class="text-2xl"></span>
          <div>
            <div class="flex items-center gap-1.5">
              <span id="w-max" class="text-sm font-bold text-zinc-800 dark:text-zinc-200"></span>
              <span class="text-zinc-300 dark:text-zinc-600">/</span>
              <span id="w-min" class="text-sm text-zinc-500 dark:text-zinc-400"></span>
            </div>
            <p id="w-desc" class="text-xs text-zinc-500 dark:text-zinc-400"></p>
          </div>
        </div>
        <div id="w-rain-box" class="text-right hidden">
          <div class="flex items-center gap-1">
            <span class="text-sm">🌧️</span>
            <span id="w-rain" class="text-sm font-bold text-blue-600 dark:text-blue-400"></span>
          </div>
          <p id="w-rain-label" class="text-[0.65rem] text-zinc-400 dark:text-zinc-500"></p>
        </div>
      </div>
      <p id="w-source" class="text-[0.65rem] text-zinc-400 dark:text-zinc-500 mt-1.5 text-right"></p>
    </div>

    <script define:vars={{ dayNumber: day.dayNumber }}>
      fetch("/api/weather")
        .then(r => r.json())
        .then(data => {
          document.getElementById("weather-skeleton")?.classList.add("hidden");
          if (!data.days) return;
          const w = data.days.find(d => d.dayNumber === dayNumber);
          if (!w) return;

          document.getElementById("weather").classList.remove("hidden");
          document.getElementById("w-emoji").textContent = w.emoji;
          document.getElementById("w-max").textContent = w.tempMax + "°C";
          document.getElementById("w-min").textContent = w.tempMin + "°C";
          document.getElementById("w-desc").textContent = w.description;

          if (w.rain > 0) {
            document.getElementById("w-rain-box").classList.remove("hidden");
            document.getElementById("w-rain").textContent = w.rain + "mm";
            document.getElementById("w-rain-label").textContent = w.rainProb !== null ? w.rainProb + "% prob." : "lluvia";
          }

          document.getElementById("w-source").textContent = data.source === "forecast"
            ? "Pronostico real"
            : "Basado en datos de mayo 2025 (referencia)";
        })
        .catch(() => {
          document.getElementById("weather-skeleton")?.classList.add("hidden");
        });
    </script>

    <!-- Flight Info -->
    {day.flightInfo && (
      <FlightCard segments={day.flightInfo.segments} bookingRef={day.flightInfo.bookingRef} />
    )}

    <!-- Route -->
    <RouteChain steps={day.route} label={day.returnRoute ? "Ruta de ida" : "Ruta del dia"} />

    <!-- Map -->
    <RouteMap steps={day.route} returnSteps={day.returnRoute} mapId={`map-day-${day.dayNumber}`} />

    <!-- Time Slots -->
    {day.timeSlots.map((slot) => (
      <TimeSlotCard slot={slot} area={day.area} />
    ))}

    <!-- Options (Day 13) -->
    {day.options && day.options.length > 0 && (
      <div class="space-y-3">
        <h2 class="text-sm font-semibold text-zinc-500 dark:text-zinc-400 uppercase tracking-wider px-1">Opciones para la tarde</h2>
        {day.options.map((opt) => (
          <div class="bg-white dark:bg-zinc-900 rounded-2xl border border-dashed border-zinc-300 dark:border-zinc-700 overflow-hidden">
            <div class="bg-zinc-50 dark:bg-zinc-800/50 px-4 py-2">
              <span class="text-sm font-semibold text-zinc-700 dark:text-zinc-300">{opt.label}</span>
            </div>
            <ul class="px-4 py-2">
              {opt.activities.map((activity) => (
                <ActivityItem activity={activity} area={day.area} />
              ))}
            </ul>
          </div>
        ))}
      </div>
    )}

    <!-- Nearby Restaurants (matches TimeSlotCard pattern) -->
    <section class="bg-white dark:bg-zinc-900 rounded-2xl shadow-sm border border-zinc-100 dark:border-zinc-800 overflow-hidden">
      <div class="bg-gradient-to-r from-orange-400 to-amber-400 px-4 py-2.5 flex items-center justify-between">
        <h3 class="text-white font-semibold text-sm">Donde comer</h3>
        <span id="restaurants-header-right" class="text-white/80 text-xs">{day.area}</span>
        <button id="refresh-restaurants" class="hidden text-[0.65rem] font-bold text-white/80 hover:text-white bg-white/20 px-2 py-0.5 rounded-full transition-colors">
          Otros resultados
        </button>
      </div>

      <div id="restaurants-prompt" class="px-4 py-4">
        <button
          id="search-restaurants"
          class="w-full text-sm text-orange-600 dark:text-orange-400 font-semibold py-2 border border-orange-200 dark:border-orange-900/50 rounded-lg hover:bg-orange-50 dark:hover:bg-orange-950/30 transition-colors flex items-center justify-center gap-1.5"
        >
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg>
          Buscar restaurantes cercanos
        </button>
      </div>

      <div id="restaurants-loading" class="hidden px-4 py-6 text-center">
        <div class="inline-block w-6 h-6 border-[3px] border-zinc-200 dark:border-zinc-700 border-t-orange-500 rounded-full animate-spin"></div>
        <p class="text-xs text-zinc-400 dark:text-zinc-500 mt-2">Buscando restaurantes...</p>
      </div>

      <div id="restaurants-list" class="hidden"></div>

      <div id="restaurants-error" class="hidden px-4 py-6 text-center">
        <p class="text-zinc-400 dark:text-zinc-500 text-sm">No se pudieron cargar los restaurantes</p>
        <button id="retry-restaurants" class="mt-2 text-xs font-semibold text-orange-600 dark:text-orange-400 hover:underline">Reintentar</button>
      </div>
    </section>

    <script define:vars={{ area: day.area }}>
      async function loadRestaurants() {
        const prompt = document.getElementById("restaurants-prompt");
        const headerRight = document.getElementById("restaurants-header-right");
        const refreshBtn = document.getElementById("refresh-restaurants");
        const loading = document.getElementById("restaurants-loading");
        const list = document.getElementById("restaurants-list");
        const error = document.getElementById("restaurants-error");

        prompt.classList.add("hidden");
        headerRight.classList.add("hidden");
        refreshBtn.classList.remove("hidden");
        loading.classList.remove("hidden");
        list.classList.add("hidden");
        error.classList.add("hidden");

        try {
          const res = await fetch(`/api/places?q=${encodeURIComponent(`restaurantes baratos buenas reseñas ${area} Tokyo`)}`);
          const data = await res.json();

          if (!Array.isArray(data) || data.length === 0) {
            loading.classList.add("hidden");
            error.classList.remove("hidden");
            return;
          }

          let html = `<ul class="divide-y divide-zinc-50 dark:divide-zinc-800/50">`;

          for (const r of data) {
            const link = r.place_id
              ? `https://maps.google.com/maps?q=place_id:${r.place_id}`
              : "#";
            const dirLink = r.place_id
              ? `https://www.google.com/maps/dir/?api=1&destination=${encodeURIComponent(r.title)}&destination_place_id=${r.place_id}`
              : null;
            const stars = r.rating ? `⭐ ${r.rating}` : "";
            const reviews = r.reviews ? `(${r.reviews})` : "";

            html += `<li class="px-4 py-3">
              <div class="flex items-start gap-2.5">
                <div class="flex-1 min-w-0">
                  <div class="flex items-start justify-between gap-2">
                    <a href="${link}" target="_blank" rel="noopener noreferrer"
                       class="font-semibold text-sm text-orange-700 dark:text-orange-300 hover:text-orange-500 dark:hover:text-orange-400 transition-colors inline-flex items-center gap-1.5">
                      ${r.title}
                      <svg class="w-3 h-3 text-blue-500 dark:text-blue-400 shrink-0" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/></svg>
                    </a>
                    ${dirLink ? `<a href="${dirLink}" target="_blank" rel="noopener noreferrer" class="shrink-0 w-7 h-7 rounded-full flex items-center justify-center hover:bg-zinc-100 dark:hover:bg-zinc-800 transition-colors" title="Como llegar"><svg class="w-3.5 h-3.5 text-zinc-400 dark:text-zinc-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7" /></svg></a>` : ""}
                  </div>
                  <div class="flex flex-wrap items-center gap-1.5 mt-1">
                    ${stars ? `<span class="text-[0.65rem] font-bold text-amber-600 dark:text-amber-400">${stars} ${reviews}</span>` : ""}
                    ${r.price ? `<span class="text-[0.65rem] font-bold px-1.5 py-0.5 rounded bg-emerald-50 text-emerald-700 dark:bg-emerald-950 dark:text-emerald-400">${r.price}</span>` : ""}
                    ${r.type ? `<span class="text-[0.65rem] text-zinc-400">${r.type}</span>` : ""}
                  </div>
                  ${r.address ? `<p class="text-[0.65rem] text-zinc-400 dark:text-zinc-500 mt-0.5 truncate">${r.address}</p>` : ""}
                </div>
              </div>
            </li>`;
          }

          html += `</ul>`;

          const mapsQuery = encodeURIComponent(`restaurantes ${area} Tokyo`);
          html += `<div class="px-4 py-2.5 border-t border-zinc-50 dark:border-zinc-800/50">
            <a href="https://www.google.com/maps/search/${mapsQuery}" target="_blank" rel="noopener noreferrer"
               class="flex items-center justify-center gap-1.5 text-xs font-semibold text-orange-600 dark:text-orange-400 hover:text-orange-500 transition-colors">
              <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/></svg>
              Ver mas en Google Maps
            </a>
          </div>`;

          list.innerHTML = html;
          loading.classList.add("hidden");
          list.classList.remove("hidden");
        } catch (err) {
          loading.classList.add("hidden");
          error.classList.remove("hidden");
        }
      }

      document.getElementById("search-restaurants")?.addEventListener("click", loadRestaurants);
      document.getElementById("refresh-restaurants")?.addEventListener("click", loadRestaurants);
      document.getElementById("retry-restaurants")?.addEventListener("click", loadRestaurants);
    </script>

    <!-- Return Route -->
    {day.returnRoute && (
      <RouteChain steps={day.returnRoute} label="Ruta de vuelta" />
    )}

    <!-- Day Navigation Arrows -->
    <div class="flex justify-between items-center pt-4">
      {prevDay ? (
        <a href={`/dia/${prevDay}`} class="flex items-center gap-1.5 text-sm text-zinc-500 dark:text-zinc-400 bg-zinc-100 dark:bg-zinc-800 px-4 py-2.5 rounded-xl hover:bg-zinc-200 dark:hover:bg-zinc-700 transition">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" /></svg>
          Dia {prevDay}
        </a>
      ) : <div />}
      {nextDay ? (
        <a href={`/dia/${nextDay}`} class="flex items-center gap-1.5 text-sm text-zinc-500 dark:text-zinc-400 bg-zinc-100 dark:bg-zinc-800 px-4 py-2.5 rounded-xl hover:bg-zinc-200 dark:hover:bg-zinc-700 transition">
          Dia {nextDay}
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
        </a>
      ) : <div />}
    </div>
  </main>
</Layout>
