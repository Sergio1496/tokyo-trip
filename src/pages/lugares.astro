---
import Layout from "../layouts/Layout.astro";
import importedPlaces from "../data/imported-places.json";

// Pre-imported places from build (already in JSON)
const buildPlaces = (importedPlaces as any[]).filter((p) => !p.inItinerary && !p.assignedDay);
---

<Layout title="Lugares guardados" activeNav="places">
  <main class="max-w-lg mx-auto px-4 py-6 space-y-6">
    <div class="text-center">
      <h1 class="text-2xl font-bold text-zinc-900 dark:text-white">Lugares guardados</h1>
      <p class="text-sm text-zinc-500 dark:text-zinc-400 mt-1" id="subtitle">
        Importa tus lugares guardados de Google Maps
      </p>
    </div>

    <!-- Drop zone -->
    <div
      id="dropzone"
      class="border-2 border-dashed border-zinc-300 dark:border-zinc-700 rounded-2xl p-6 text-center cursor-pointer hover:border-violet-400 dark:hover:border-violet-500 hover:bg-violet-50 dark:hover:bg-violet-950/20 transition-colors"
    >
      <svg class="w-10 h-10 mx-auto text-zinc-400 dark:text-zinc-500 mb-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5m-13.5-9L12 3m0 0l4.5 4.5M12 3v13.5" />
      </svg>
      <p class="text-sm font-medium text-zinc-600 dark:text-zinc-400">Arrastra aqui tus CSV de Google Takeout</p>
      <p class="text-xs text-zinc-400 dark:text-zinc-500 mt-1">o pulsa para seleccionar archivos</p>
      <input type="file" id="fileInput" multiple accept=".csv" class="hidden" />
    </div>

    <!-- Places container -->
    <div id="places-container"></div>
  </main>
</Layout>

<script define:vars={{ buildPlaces }}>
  const CAT_MAP = {
    "Bares": "food",
    "Ramen kyoto": "food",
    "Ramen tokio": "food",
    "Restaurantes Teppanyaki": "food",
    "Restaurantes_cafeterias Tokyo": "food",
    "Restaurantes": "food",
    "Templos": "temple",
    "Sitios donde ir Tokyo": "attraction",
    "Sitios donde ir": "attraction",
    "Sitios favoritos": "attraction",
    "Quiero ir": "attraction",
  };

  const CAT_EMOJI = { food: "🍜", temple: "⛩️", attraction: "📍" };
  const CAT_LABEL = { food: "Restaurante", temple: "Templo", attraction: "Visita" };
  const CAT_COLORS = {
    food: "bg-orange-100 text-orange-700 dark:bg-orange-900/50 dark:text-orange-300",
    temple: "bg-red-100 text-red-700 dark:bg-red-900/50 dark:text-red-300",
    attraction: "bg-sky-100 text-sky-700 dark:bg-sky-900/50 dark:text-sky-300",
  };
  const GRADIENTS = {
    food: "from-orange-500 to-amber-500",
    temple: "from-red-500 to-rose-500",
    attraction: "from-violet-500 to-purple-500",
  };

  function getStored() {
    try { return JSON.parse(localStorage.getItem("imported-places") || "[]"); }
    catch { return []; }
  }

  function setStored(places) {
    localStorage.setItem("imported-places", JSON.stringify(places));
  }

  function parseCsv(content, fileName) {
    const listName = fileName.replace(".csv", "");
    const cat = CAT_MAP[listName] || guessCategory(listName);
    const lines = content.split("\n");
    const places = [];
    for (let i = 2; i < lines.length; i++) {
      const line = lines[i].trim();
      if (!line || line === ",,,,") continue;
      const parts = line.split(",");
      const title = parts[0]?.trim();
      const note = parts[1]?.trim() || "";
      const url = parts[2]?.trim() || "";
      if (title && url) {
        places.push({ title, note, url, list: listName, cat });
      }
    }
    return places;
  }

  function guessCategory(listName) {
    const lower = listName.toLowerCase();
    if (lower.includes("ramen") || lower.includes("restaurante") || lower.includes("cafe") || lower.includes("bar") || lower.includes("sushi")) return "food";
    if (lower.includes("templo") || lower.includes("shrine") || lower.includes("santuario")) return "temple";
    return "attraction";
  }

  function renderPlaces() {
    const stored = getStored();
    const all = [...buildPlaces, ...stored];

    // Deduplicate by URL
    const seen = new Set();
    const unique = all.filter(p => {
      if (seen.has(p.url)) return false;
      seen.add(p.url);
      return true;
    });

    const container = document.getElementById("places-container");
    const subtitle = document.getElementById("subtitle");

    if (unique.length === 0) {
      container.innerHTML = `
        <div class="text-center py-12 text-zinc-400 dark:text-zinc-500">
          <p class="text-lg">No hay lugares importados</p>
          <p class="text-sm mt-1">Arrastra tus CSV de Google Takeout arriba</p>
        </div>
      `;
      subtitle.textContent = "Importa tus lugares guardados de Google Maps";
      return;
    }

    subtitle.textContent = `${unique.length} lugares importados de Google Maps`;

    // Group by list
    const byList = new Map();
    for (const p of unique) {
      const list = p.list || "Sin lista";
      if (!byList.has(list)) byList.set(list, []);
      byList.get(list).push(p);
    }

    let html = "";
    for (const [listName, places] of byList) {
      const firstCat = places[0]?.cat || "attraction";
      const gradient = GRADIENTS[firstCat] || GRADIENTS.attraction;

      html += `
        <section class="bg-white dark:bg-zinc-900 rounded-2xl border border-zinc-100 dark:border-zinc-800 overflow-hidden shadow-sm mb-4">
          <div class="bg-gradient-to-r ${gradient} px-4 py-3 flex items-center justify-between">
            <h2 class="text-white font-semibold text-sm">${listName}</h2>
            <span class="text-white/80 text-xs">${places.length} lugares</span>
          </div>
          <ul class="divide-y divide-zinc-50 dark:divide-zinc-800">
      `;

      for (const place of places) {
        const emoji = place.cat ? (CAT_EMOJI[place.cat] || "📍") : "📌";
        const catBadge = place.cat ? `<span class="px-1.5 py-0.5 rounded text-[0.6rem] font-bold uppercase ${CAT_COLORS[place.cat] || ""}">${CAT_LABEL[place.cat] || ""}</span>` : "";

        html += `
          <li class="px-4 py-3">
            <div class="flex items-start gap-2">
              <span class="mt-0.5 text-sm shrink-0">${emoji}</span>
              <div class="flex-1 min-w-0">
                <div class="flex flex-wrap items-center gap-1.5">
                  <a href="${place.url}" target="_blank" rel="noopener noreferrer"
                    class="font-medium text-sm text-zinc-900 dark:text-zinc-100 hover:text-blue-600 dark:hover:text-blue-400 transition-colors inline-flex items-center gap-1">
                    ${place.title}
                    <svg class="w-3 h-3 text-blue-500 dark:text-blue-400 shrink-0" viewBox="0 0 24 24" fill="currentColor">
                      <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/>
                    </svg>
                  </a>
                  ${catBadge}
                </div>
                ${place.note ? `<p class="text-xs text-zinc-500 dark:text-zinc-400 mt-0.5">${place.note}</p>` : ""}
              </div>
            </div>
          </li>
        `;
      }

      html += `</ul></section>`;
    }

    container.innerHTML = html;
  }

  function handleFiles(files) {
    const stored = getStored();
    const existingUrls = new Set(stored.map(p => p.url));
    // Also exclude build-time places
    for (const p of buildPlaces) existingUrls.add(p.url);

    let added = 0;

    const readPromises = Array.from(files).map(file => {
      return new Promise((resolve) => {
        const reader = new FileReader();
        reader.onload = (e) => {
          const places = parseCsv(e.target.result, file.name);
          for (const p of places) {
            if (!existingUrls.has(p.url)) {
              stored.push(p);
              existingUrls.add(p.url);
              added++;
            }
          }
          resolve();
        };
        reader.readAsText(file);
      });
    });

    Promise.all(readPromises).then(() => {
      setStored(stored);
      renderPlaces();

      // Show toast
      const toast = document.createElement("div");
      toast.className = "fixed top-4 left-1/2 -translate-x-1/2 bg-emerald-600 text-white px-4 py-2 rounded-xl text-sm font-medium shadow-lg z-50 transition-opacity";
      toast.textContent = `${added} lugares importados`;
      document.body.appendChild(toast);
      setTimeout(() => { toast.style.opacity = "0"; setTimeout(() => toast.remove(), 300); }, 2000);
    });
  }

  // Dropzone
  const dropzone = document.getElementById("dropzone");
  const fileInput = document.getElementById("fileInput");

  dropzone.addEventListener("click", () => fileInput.click());
  fileInput.addEventListener("change", (e) => handleFiles(e.target.files));

  dropzone.addEventListener("dragover", (e) => {
    e.preventDefault();
    dropzone.classList.add("border-violet-400", "bg-violet-50", "dark:border-violet-500", "dark:bg-violet-950/20");
  });
  dropzone.addEventListener("dragleave", () => {
    dropzone.classList.remove("border-violet-400", "bg-violet-50", "dark:border-violet-500", "dark:bg-violet-950/20");
  });
  dropzone.addEventListener("drop", (e) => {
    e.preventDefault();
    dropzone.classList.remove("border-violet-400", "bg-violet-50", "dark:border-violet-500", "dark:bg-violet-950/20");
    const csvFiles = Array.from(e.dataTransfer.files).filter(f => f.name.endsWith(".csv"));
    if (csvFiles.length) handleFiles(csvFiles);
  });

  // Initial render
  renderPlaces();
</script>
