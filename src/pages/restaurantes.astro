---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Slot de restaurantes" activeNav="discover">
  <main class="max-w-lg mx-auto px-4 py-6 space-y-6">
    <div class="text-center">
      <h1 class="text-2xl font-bold text-zinc-900 dark:text-white">Slot de restaurantes</h1>
      <p class="text-sm text-zinc-500 dark:text-zinc-400 mt-1">
        Gira las ruedas y descubre donde comer en Tokyo
      </p>
    </div>

    <!-- Slot Machine -->
    <div class="bg-white dark:bg-zinc-900 rounded-2xl border border-zinc-100 dark:border-zinc-800 p-5 shadow-sm overflow-hidden">
      <div class="text-center mb-4">
        <span class="text-zinc-400 dark:text-zinc-500 font-bold tracking-widest text-xs uppercase">Tokyo Eats</span>
      </div>

      <!-- Reels -->
      <div class="flex gap-2 justify-center mb-5">
        <div class="flex flex-col items-center gap-1.5">
          <span class="text-[0.65rem] font-bold text-zinc-400 dark:text-zinc-500 uppercase tracking-widest">Comida</span>
          <div class="reel-window w-24 h-[5.5rem] bg-zinc-50 dark:bg-zinc-800 rounded-xl overflow-hidden flex items-center justify-center shadow-inner border border-zinc-200 dark:border-zinc-700 relative">
            <div class="absolute inset-x-0 top-0 h-3 bg-gradient-to-b from-zinc-50 dark:from-zinc-800 to-transparent z-10 pointer-events-none"></div>
            <div class="absolute inset-x-0 bottom-0 h-3 bg-gradient-to-t from-zinc-50 dark:from-zinc-800 to-transparent z-10 pointer-events-none"></div>
            <div id="reel-food" class="text-center transition-transform duration-200">
              <span class="text-3xl block leading-none">🍜</span>
              <span class="text-[0.65rem] font-bold text-zinc-700 block mt-1">Ramen</span>
            </div>
          </div>
        </div>

        <div class="flex flex-col items-center gap-1.5">
          <span class="text-[0.65rem] font-bold text-zinc-400 dark:text-zinc-500 uppercase tracking-widest">Zona</span>
          <div class="reel-window w-24 h-[5.5rem] bg-zinc-50 dark:bg-zinc-800 rounded-xl overflow-hidden flex items-center justify-center shadow-inner border border-zinc-200 dark:border-zinc-700 relative">
            <div class="absolute inset-x-0 top-0 h-3 bg-gradient-to-b from-zinc-50 dark:from-zinc-800 to-transparent z-10 pointer-events-none"></div>
            <div class="absolute inset-x-0 bottom-0 h-3 bg-gradient-to-t from-zinc-50 dark:from-zinc-800 to-transparent z-10 pointer-events-none"></div>
            <div id="reel-zone" class="text-center transition-transform duration-200">
              <span class="text-3xl block leading-none">🏙️</span>
              <span class="text-[0.65rem] font-bold text-zinc-700 block mt-1">Shinjuku</span>
            </div>
          </div>
        </div>

        <div class="flex flex-col items-center gap-1.5">
          <span class="text-[0.65rem] font-bold text-zinc-400 dark:text-zinc-500 uppercase tracking-widest">Precio</span>
          <div class="reel-window w-24 h-[5.5rem] bg-zinc-50 dark:bg-zinc-800 rounded-xl overflow-hidden flex items-center justify-center shadow-inner border border-zinc-200 dark:border-zinc-700 relative">
            <div class="absolute inset-x-0 top-0 h-3 bg-gradient-to-b from-zinc-50 dark:from-zinc-800 to-transparent z-10 pointer-events-none"></div>
            <div class="absolute inset-x-0 bottom-0 h-3 bg-gradient-to-t from-zinc-50 dark:from-zinc-800 to-transparent z-10 pointer-events-none"></div>
            <div id="reel-price" class="text-center transition-transform duration-200">
              <span class="text-3xl block leading-none">💴</span>
              <span class="text-[0.65rem] font-bold text-zinc-700 block mt-1">¥¥</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Geo toggle -->
      <div class="flex items-center justify-center gap-2 mb-4">
        <button
          id="geo-toggle"
          class="flex items-center gap-2 px-4 py-2 rounded-xl text-sm font-semibold transition-all border-2 border-zinc-200 dark:border-zinc-700 text-zinc-500 dark:text-zinc-400 hover:border-blue-400 dark:hover:border-blue-500"
        >
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
          <span id="geo-label">Usar mi ubicación</span>
        </button>
      </div>

      <!-- Spin button -->
      <button
        id="spin-btn"
        class="w-full bg-red-500 hover:bg-red-400 text-white font-bold py-3 rounded-xl text-base active:scale-95 transition-all flex items-center justify-center gap-2"
      >
        🎰 GIRAR
      </button>

    </div>

    <!-- Combo display -->
    <div id="combo" class="hidden">
      <div class="bg-white dark:bg-zinc-900 rounded-2xl border border-zinc-100 dark:border-zinc-800 p-4 text-center shadow-sm">
        <p class="text-xs text-zinc-400 dark:text-zinc-500 uppercase tracking-wider font-semibold mb-1">Combinacion</p>
        <p id="combo-text" class="font-bold text-zinc-900 dark:text-white text-lg"></p>
      </div>
    </div>

    <!-- Loading -->
    <div id="loading" class="hidden text-center py-6">
      <div class="inline-block w-8 h-8 border-4 border-zinc-200 dark:border-zinc-700 border-t-red-500 rounded-full animate-spin"></div>
      <p class="text-sm text-zinc-500 dark:text-zinc-400 mt-3">Buscando en Google Maps...</p>
    </div>

    <!-- Results -->
    <div id="results" class="hidden space-y-3">
      <div id="results-list"></div>

      <button
        id="respin-btn"
        class="w-full bg-zinc-100 dark:bg-zinc-800 text-zinc-700 dark:text-zinc-300 font-semibold py-3 rounded-xl hover:bg-zinc-200 dark:hover:bg-zinc-700 transition-colors text-sm"
      >
        🎰 Girar de nuevo
      </button>
    </div>

    <!-- Back link -->
    <div class="text-center pt-2">
      <a href="/random" class="text-sm text-zinc-400 hover:text-zinc-600 dark:hover:text-zinc-300 transition-colors">
        ← Barrio aleatorio
      </a>
    </div>
  </main>
</Layout>

<script>
  const FOODS = [
    { label: "Ramen", emoji: "🍜", query: "ramen" },
    { label: "Sushi", emoji: "🍣", query: "sushi" },
    { label: "Yakiniku", emoji: "🍖", query: "yakiniku" },
    { label: "Curry", emoji: "🍛", query: "curry japonés" },
    { label: "Gyoza", emoji: "🥟", query: "gyoza" },
    { label: "Tempura", emoji: "🍤", query: "tempura" },
    { label: "Tonkatsu", emoji: "🐷", query: "tonkatsu" },
    { label: "Udon", emoji: "🍝", query: "udon" },
    { label: "Izakaya", emoji: "🍶", query: "izakaya" },
    { label: "Takoyaki", emoji: "🐙", query: "takoyaki" },
    { label: "Okonomiyaki", emoji: "🥞", query: "okonomiyaki" },
    { label: "Soba", emoji: "🥢", query: "soba" },
  ];

  const ZONES = [
    { label: "Shinjuku", emoji: "🏙️" },
    { label: "Shibuya", emoji: "🔀" },
    { label: "Asakusa", emoji: "⛩️" },
    { label: "Ueno", emoji: "🏛️" },
    { label: "Ikebukuro", emoji: "🎮" },
    { label: "Akihabara", emoji: "⚡" },
    { label: "Ginza", emoji: "💎" },
    { label: "Roppongi", emoji: "🌃" },
    { label: "Nakano", emoji: "🎭" },
    { label: "Tsukiji", emoji: "🐟" },
    { label: "Harajuku", emoji: "🌈" },
    { label: "Kappabashi", emoji: "🍳" },
  ];

  const PRICES = [
    { label: "¥", emoji: "💰", query: "barato cheap", desc: "Economico" },
    { label: "¥¥", emoji: "💴", query: "", desc: "Moderado" },
    { label: "¥¥¥", emoji: "💎", query: "best mejor premium", desc: "Premium" },
  ];

  const reelFood = document.getElementById("reel-food")!;
  const reelZone = document.getElementById("reel-zone")!;
  const reelPrice = document.getElementById("reel-price")!;
  const spinBtn = document.getElementById("spin-btn") as HTMLButtonElement;
  const respinBtn = document.getElementById("respin-btn") as HTMLButtonElement;
  const loadingEl = document.getElementById("loading")!;
  const resultsEl = document.getElementById("results")!;
  const resultsList = document.getElementById("results-list")!;
  const comboEl = document.getElementById("combo")!;
  const comboText = document.getElementById("combo-text")!;
  const geoToggle = document.getElementById("geo-toggle") as HTMLButtonElement;
  const geoLabel = document.getElementById("geo-label")!;

  let spinning = false;
  let geoMode = false;
  let userCoords: { lat: number; lng: number } | null = null;

  geoToggle.addEventListener("click", async () => {
    if (geoMode) {
      // Disable geo mode
      geoMode = false;
      userCoords = null;
      geoToggle.classList.remove("border-blue-500", "dark:border-blue-400", "bg-blue-50", "dark:bg-blue-950", "text-blue-600", "dark:text-blue-400");
      geoToggle.classList.add("border-zinc-200", "dark:border-zinc-700", "text-zinc-500", "dark:text-zinc-400");
      geoLabel.textContent = "Usar mi ubicación";
      // Restore zone reel
      reelZone.parentElement!.parentElement!.classList.remove("hidden");
      return;
    }

    if (!navigator.geolocation) {
      geoLabel.textContent = "GPS no disponible";
      return;
    }

    geoLabel.textContent = "Localizando...";
    geoToggle.disabled = true;

    try {
      const pos = await new Promise<GeolocationPosition>((resolve, reject) => {
        navigator.geolocation.getCurrentPosition(resolve, reject, {
          enableHighAccuracy: true,
          timeout: 10000,
        });
      });

      userCoords = { lat: pos.coords.latitude, lng: pos.coords.longitude };
      geoMode = true;

      geoToggle.classList.remove("border-zinc-200", "dark:border-zinc-700", "text-zinc-500", "dark:text-zinc-400");
      geoToggle.classList.add("border-blue-500", "dark:border-blue-400", "bg-blue-50", "dark:bg-blue-950", "text-blue-600", "dark:text-blue-400");
      geoLabel.textContent = "Cerca de mí ✓";

      // Hide zone reel
      reelZone.parentElement!.parentElement!.classList.add("hidden");
    } catch (err: any) {
      const msg = err.code === 1 ? "Permiso denegado" : "Error de GPS";
      geoLabel.textContent = msg;
      setTimeout(() => { geoLabel.textContent = "Usar mi ubicación"; }, 2000);
    } finally {
      geoToggle.disabled = false;
    }
  });

  function renderItem(el: HTMLElement, item: { emoji: string; label: string }) {
    el.innerHTML = `<span class="text-3xl block leading-none">${item.emoji}</span><span class="text-[0.65rem] font-bold text-zinc-700 block mt-1">${item.label}</span>`;
  }

  function animateReel<T extends { emoji: string; label: string }>(
    el: HTMLElement,
    items: T[],
    duration: number,
  ): Promise<T> {
    return new Promise((resolve) => {
      const finalIndex = Math.floor(Math.random() * items.length);
      const startTime = performance.now();
      let idx = 0;

      function tick() {
        const elapsed = performance.now() - startTime;
        const progress = Math.min(elapsed / duration, 1);

        if (progress >= 1) {
          renderItem(el, items[finalIndex]);
          el.style.filter = "";
          el.style.transform = "scale(1.15)";
          setTimeout(() => {
            el.style.transform = "";
          }, 200);
          resolve(items[finalIndex]);
          return;
        }

        idx = (idx + 1) % items.length;
        renderItem(el, items[idx]);

        const blur = (1 - progress) * 2;
        el.style.filter = `blur(${blur}px)`;

        const delay = 40 + progress * progress * 280;
        setTimeout(tick, delay);
      }

      tick();
    });
  }

  async function spin() {
    if (spinning) return;
    spinning = true;

    spinBtn.disabled = true;
    spinBtn.classList.add("opacity-50");
    resultsEl.classList.add("hidden");
    comboEl.classList.add("hidden");

    const reels: Promise<any>[] = [
      animateReel(reelFood, FOODS, 1200),
      geoMode ? Promise.resolve(null) : animateReel(reelZone, ZONES, 1800),
      animateReel(reelPrice, PRICES, 2400),
    ];
    const [food, zone, price] = await Promise.all(reels);

    // Build search query
    const priceQuery = price.query ? ` ${price.query}` : "";
    const zoneName = geoMode ? "mi zona" : zone.label;
    const query = geoMode
      ? `${food.query}${priceQuery}`
      : `${food.query}${priceQuery} ${zone.label} Tokyo`;

    comboText.textContent = `${food.emoji} ${food.label} ${price.label} en ${zoneName}`;
    comboEl.classList.remove("hidden");
    loadingEl.classList.remove("hidden");

    try {
      let apiUrl = `/api/places?q=${encodeURIComponent(query)}`;
      if (geoMode && userCoords) {
        apiUrl += `&lat=${userCoords.lat}&lng=${userCoords.lng}`;
      }
      const res = await fetch(apiUrl);
      const data = await res.json();

      if (data.error || !Array.isArray(data) || data.length === 0) {
        resultsList.innerHTML = `
          <div class="text-center py-8 text-zinc-400 dark:text-zinc-500">
            <p class="text-3xl mb-2">😅</p>
            <p class="font-medium">No encontramos nada</p>
            <p class="text-sm mt-1">Prueba a girar de nuevo</p>
          </div>`;
      } else {
        renderResults(data, food, zone || { label: "mi zona", emoji: "📍" }, price);
      }
    } catch (err: any) {
      resultsList.innerHTML = `
        <div class="text-center py-8 text-zinc-400 dark:text-zinc-500">
          <p class="text-3xl mb-2">⚠️</p>
          <p class="font-medium">Error al buscar</p>
          <p class="text-sm mt-1">${err.message || "Intenta de nuevo"}</p>
        </div>`;
    }

    loadingEl.classList.add("hidden");
    resultsEl.classList.remove("hidden");
    spinBtn.disabled = false;
    spinBtn.classList.remove("opacity-50");
    spinning = false;

    resultsEl.scrollIntoView({ behavior: "smooth", block: "start" });
  }

  interface PlaceResult {
    title: string;
    rating?: number;
    reviews?: number;
    price?: string;
    type?: string;
    address?: string;
    place_id?: string;
  }

  function renderResults(
    results: PlaceResult[],
    food: (typeof FOODS)[0],
    zone: (typeof ZONES)[0],
    price: (typeof PRICES)[0],
  ) {
    let html = `
      <div class="bg-white dark:bg-zinc-900 rounded-2xl border border-zinc-100 dark:border-zinc-800 overflow-hidden shadow-sm">
        <div class="bg-gradient-to-r from-red-500 to-orange-500 px-4 py-3">
          <h3 class="text-white font-bold text-sm">${food.emoji} ${food.label} en ${zone.label}</h3>
          <p class="text-white/70 text-xs">${results.length} resultados · ${price.desc}</p>
        </div>
        <ul class="divide-y divide-zinc-50 dark:divide-zinc-800/50">`;

    for (const r of results) {
      const link = r.place_id
        ? `https://maps.google.com/maps?q=place_id:${r.place_id}`
        : "#";
      const dirLink = r.place_id
        ? `https://www.google.com/maps/dir/?api=1&destination=${encodeURIComponent(r.title)}&destination_place_id=${r.place_id}`
        : null;
      const stars = r.rating ? `⭐ ${r.rating}` : "";
      const reviews = r.reviews ? `(${r.reviews})` : "";

      html += `
        <li class="px-4 py-3">
          <div class="flex items-start gap-2.5">
            <div class="flex-1 min-w-0">
              <div class="flex items-start justify-between gap-2">
                <a href="${link}" target="_blank" rel="noopener noreferrer"
                   class="font-semibold text-sm text-zinc-800 dark:text-zinc-200 hover:text-red-500 dark:hover:text-red-400 transition-colors inline-flex items-center gap-1.5">
                  ${r.title}
                  <svg class="w-3 h-3 text-blue-500 shrink-0" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/></svg>
                </a>
                ${dirLink ? `<a href="${dirLink}" target="_blank" rel="noopener noreferrer" class="shrink-0 w-7 h-7 rounded-full flex items-center justify-center hover:bg-zinc-100 dark:hover:bg-zinc-800 transition-colors" title="Como llegar"><svg class="w-3.5 h-3.5 text-zinc-400 dark:text-zinc-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7" /></svg></a>` : ""}
              </div>
              <div class="flex flex-wrap items-center gap-1.5 mt-1">
                ${stars ? `<span class="text-[0.65rem] font-bold text-amber-600 dark:text-amber-400">${stars} ${reviews}</span>` : ""}
                ${r.price ? `<span class="text-[0.65rem] font-bold px-1.5 py-0.5 rounded bg-emerald-50 text-emerald-700 dark:bg-emerald-950 dark:text-emerald-400">${r.price}</span>` : ""}
                ${r.type ? `<span class="text-[0.65rem] text-zinc-400">${r.type}</span>` : ""}
              </div>
              ${r.address ? `<p class="text-[0.65rem] text-zinc-400 dark:text-zinc-500 mt-0.5 truncate">${r.address}</p>` : ""}
            </div>
          </div>
        </li>`;
    }

    html += `</ul></div>`;

    // Google Maps link for full search
    let mapsUrl: string;
    if (geoMode && userCoords) {
      const mapsQuery = encodeURIComponent(food.query);
      mapsUrl = `https://www.google.com/maps/search/${mapsQuery}/@${userCoords.lat},${userCoords.lng},15z`;
    } else {
      const mapsQuery = encodeURIComponent(`${food.query} ${zone.label} Tokyo`);
      mapsUrl = `https://www.google.com/maps/search/${mapsQuery}`;
    }
    html += `
      <a href="${mapsUrl}" target="_blank" rel="noopener noreferrer"
         class="flex items-center justify-center gap-2 bg-blue-500 text-white font-semibold px-6 py-3 rounded-xl shadow hover:bg-blue-600 transition text-sm">
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/></svg>
        Ver todos en Google Maps
      </a>`;

    resultsList.innerHTML = html;
  }

  spinBtn.addEventListener("click", spin);
  respinBtn.addEventListener("click", spin);
</script>

<style>
  .reel-window {
    box-shadow: inset 0 2px 8px rgba(0, 0, 0, 0.1);
  }
</style>
