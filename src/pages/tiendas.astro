---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Chollos - Tiendas segunda mano" activeNav="discover">
  <main class="max-w-lg mx-auto px-4 py-6 space-y-6">
    <div class="text-center">
      <h1 class="text-2xl font-bold text-zinc-900 dark:text-white">Chollos</h1>
      <p class="text-sm text-zinc-500 dark:text-zinc-400 mt-1">
        Encuentra tiendas de segunda mano cerca de ti
      </p>
    </div>

    <!-- Category selector -->
    <div class="grid grid-cols-2 gap-2">
      <button data-cat="all" class="cat-btn active bg-emerald-500 text-white font-bold px-3 py-3 rounded-xl text-sm active:scale-95 transition-all">
        🏷️ Todas
      </button>
      <button data-cat="electronics" class="cat-btn bg-zinc-100 dark:bg-zinc-800 text-zinc-700 dark:text-zinc-300 font-bold px-3 py-3 rounded-xl text-sm active:scale-95 transition-all">
        🎮 Electro / Games
      </button>
      <button data-cat="fashion" class="cat-btn bg-zinc-100 dark:bg-zinc-800 text-zinc-700 dark:text-zinc-300 font-bold px-3 py-3 rounded-xl text-sm active:scale-95 transition-all">
        👗 Moda
      </button>
      <button data-cat="otaku" class="cat-btn bg-zinc-100 dark:bg-zinc-800 text-zinc-700 dark:text-zinc-300 font-bold px-3 py-3 rounded-xl text-sm active:scale-95 transition-all">
        🎌 Anime / Manga
      </button>
    </div>

    <!-- Search mode -->
    <div class="flex gap-2">
      <button
        id="geo-btn"
        class="flex-1 flex items-center justify-center gap-2 bg-blue-500 hover:bg-blue-400 text-white font-bold py-3 rounded-xl text-sm active:scale-95 transition-all"
      >
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
        </svg>
        <span id="geo-label">Buscar cerca de mí</span>
      </button>
      <button
        id="zone-btn"
        class="flex items-center justify-center gap-1 bg-zinc-200 dark:bg-zinc-700 hover:bg-zinc-300 dark:hover:bg-zinc-600 text-zinc-700 dark:text-zinc-300 font-bold px-4 py-3 rounded-xl text-sm active:scale-95 transition-all"
        title="Buscar por zona"
      >
        🗾
      </button>
    </div>

    <!-- Zone selector (hidden by default) -->
    <div id="zone-selector" class="hidden">
      <div class="bg-white dark:bg-zinc-900 rounded-2xl border border-zinc-100 dark:border-zinc-800 p-4 shadow-sm">
        <p class="text-xs font-semibold text-zinc-400 dark:text-zinc-500 uppercase tracking-wider mb-3">Elegir zona</p>
        <div class="grid grid-cols-3 gap-2" id="zone-grid"></div>
      </div>
    </div>

    <!-- Loading -->
    <div id="loading" class="hidden text-center py-8">
      <div class="inline-block w-8 h-8 border-4 border-zinc-200 dark:border-zinc-700 border-t-emerald-500 rounded-full animate-spin"></div>
      <p class="text-sm text-zinc-500 dark:text-zinc-400 mt-3" id="loading-text">Localizando...</p>
    </div>

    <!-- Results -->
    <div id="results" class="hidden space-y-3">
      <div id="results-header"></div>
      <div id="results-list"></div>
    </div>

    <!-- Back link -->
    <div class="text-center pt-2">
      <a href="/random" class="text-sm text-zinc-400 hover:text-zinc-600 dark:hover:text-zinc-300 transition-colors">
        ← Descubrir
      </a>
    </div>
  </main>
</Layout>

<script>
  const CHAINS: Record<string, { name: string; nameJp: string; emoji: string; cat: string; queries: string[] }> = {
    hardoff:    { name: "Hard Off", nameJp: "ハードオフ", emoji: "📀", cat: "electronics", queries: ["Hard Off ハードオフ"] },
    bookoff:    { name: "Book Off", nameJp: "ブックオフ", emoji: "📚", cat: "otaku", queries: ["Book Off ブックオフ"] },
    offhouse:   { name: "Off House", nameJp: "オフハウス", emoji: "🏠", cat: "all", queries: ["Off House オフハウス"] },
    hobbyoff:   { name: "Hobby Off", nameJp: "ホビーオフ", emoji: "🎯", cat: "otaku", queries: ["Hobby Off ホビーオフ"] },
    modeoff:    { name: "Mode Off", nameJp: "モードオフ", emoji: "👗", cat: "fashion", queries: ["Mode Off モードオフ"] },
    treasure:   { name: "Treasure Factory", nameJp: "トレジャーファクトリー", emoji: "💎", cat: "all", queries: ["Treasure Factory トレジャーファクトリー"] },
    secondst:   { name: "2nd Street", nameJp: "セカンドストリート", emoji: "🏪", cat: "fashion", queries: ["2nd Street セカンドストリート"] },
    mandarake:  { name: "Mandarake", nameJp: "まんだらけ", emoji: "🎌", cat: "otaku", queries: ["Mandarake まんだらけ"] },
    surugaya:   { name: "Suruga-ya", nameJp: "駿河屋", emoji: "🎮", cat: "otaku", queries: ["駿河屋 Suruga-ya"] },
    janso:      { name: "Janso", nameJp: "ジャンクストアー", emoji: "🔧", cat: "electronics", queries: ["ジャンクショップ junk store"] },
    recycle:    { name: "Recycle Shop", nameJp: "リサイクルショップ", emoji: "♻️", cat: "all", queries: ["リサイクルショップ"] },
  };

  const ZONES = [
    "Akihabara", "Shinjuku", "Shibuya", "Ikebukuro", "Nakano",
    "Ueno", "Shimokitazawa", "Koenji", "Machida", "Ochanomizu",
    "Harajuku", "Jimbocho",
  ];

  const CAT_QUERIES: Record<string, string[]> = {
    all: ["Hard Off", "Book Off", "Treasure Factory", "2nd Street", "リサイクルショップ"],
    electronics: ["Hard Off ハードオフ", "じゃんぱら janpara", "ソフマップ sofmap"],
    fashion: ["Mode Off モードオフ", "2nd Street セカンドストリート", "古着屋 vintage clothing"],
    otaku: ["Mandarake まんだらけ", "Book Off ブックオフ", "駿河屋 surugaya", "Hobby Off"],
  };

  let activeCat = "all";
  let userCoords: { lat: number; lng: number } | null = null;

  const geoBtn = document.getElementById("geo-btn") as HTMLButtonElement;
  const geoLabelEl = document.getElementById("geo-label")!;
  const zoneBtnEl = document.getElementById("zone-btn") as HTMLButtonElement;
  const zoneSel = document.getElementById("zone-selector")!;
  const zoneGrid = document.getElementById("zone-grid")!;
  const loadingEl = document.getElementById("loading")!;
  const loadingText = document.getElementById("loading-text")!;
  const resultsEl = document.getElementById("results")!;
  const resultsHeader = document.getElementById("results-header")!;
  const resultsList = document.getElementById("results-list")!;

  // Build zone grid
  for (const zone of ZONES) {
    const btn = document.createElement("button");
    btn.className = "text-xs font-semibold px-2 py-2 rounded-lg bg-zinc-50 dark:bg-zinc-800 text-zinc-600 dark:text-zinc-400 hover:bg-emerald-50 hover:text-emerald-700 dark:hover:bg-emerald-950 dark:hover:text-emerald-400 transition-colors";
    btn.textContent = zone;
    btn.addEventListener("click", () => searchByZone(zone));
    zoneGrid.appendChild(btn);
  }

  // Category buttons
  document.querySelectorAll<HTMLButtonElement>(".cat-btn").forEach(btn => {
    btn.addEventListener("click", () => {
      document.querySelectorAll(".cat-btn").forEach(b => {
        b.classList.remove("bg-emerald-500", "text-white", "active");
        b.classList.add("bg-zinc-100", "dark:bg-zinc-800", "text-zinc-700", "dark:text-zinc-300");
      });
      btn.classList.remove("bg-zinc-100", "dark:bg-zinc-800", "text-zinc-700", "dark:text-zinc-300");
      btn.classList.add("bg-emerald-500", "text-white", "active");
      activeCat = btn.dataset.cat || "all";
    });
  });

  // Zone toggle
  zoneBtnEl.addEventListener("click", () => {
    zoneSel.classList.toggle("hidden");
  });

  // Geo search
  geoBtn.addEventListener("click", async () => {
    if (!navigator.geolocation) {
      geoLabelEl.textContent = "GPS no disponible";
      return;
    }

    geoLabelEl.textContent = "Localizando...";
    geoBtn.disabled = true;

    try {
      const pos = await new Promise<GeolocationPosition>((resolve, reject) => {
        navigator.geolocation.getCurrentPosition(resolve, reject, {
          enableHighAccuracy: true,
          timeout: 10000,
        });
      });

      userCoords = { lat: pos.coords.latitude, lng: pos.coords.longitude };
      await searchNearby();
    } catch (err: any) {
      const msg = err.code === 1 ? "Permiso denegado" : "Error de GPS";
      geoLabelEl.textContent = msg;
      setTimeout(() => { geoLabelEl.textContent = "Buscar cerca de mí"; }, 2000);
    } finally {
      geoBtn.disabled = false;
      geoLabelEl.textContent = "Buscar cerca de mí";
    }
  });

  async function searchNearby() {
    showLoading("Buscando tiendas cerca de ti...");
    const queries = CAT_QUERIES[activeCat] || CAT_QUERIES.all;

    const allResults: any[] = [];
    const seen = new Set<string>();

    // Run queries in parallel (max 2 to avoid rate limits)
    for (let i = 0; i < queries.length; i += 2) {
      const batch = queries.slice(i, i + 2);
      const results = await Promise.all(
        batch.map(q => fetchPlaces(q, userCoords))
      );
      for (const items of results) {
        for (const item of items) {
          if (!seen.has(item.title)) {
            seen.add(item.title);
            allResults.push(item);
          }
        }
      }
    }

    renderResults(allResults, "Cerca de ti");
  }

  async function searchByZone(zone: string) {
    zoneSel.classList.add("hidden");
    showLoading(`Buscando en ${zone}...`);

    const queries = CAT_QUERIES[activeCat] || CAT_QUERIES.all;
    const allResults: any[] = [];
    const seen = new Set<string>();

    for (let i = 0; i < queries.length; i += 2) {
      const batch = queries.slice(i, i + 2);
      const results = await Promise.all(
        batch.map(q => fetchPlaces(`${q} ${zone} Tokyo`, null))
      );
      for (const items of results) {
        for (const item of items) {
          if (!seen.has(item.title)) {
            seen.add(item.title);
            allResults.push(item);
          }
        }
      }
    }

    renderResults(allResults, zone);
  }

  async function fetchPlaces(query: string, coords: { lat: number; lng: number } | null): Promise<any[]> {
    try {
      let url = `/api/places?q=${encodeURIComponent(query)}`;
      if (coords) {
        url += `&lat=${coords.lat}&lng=${coords.lng}`;
      }
      const res = await fetch(url);
      const data = await res.json();
      if (data.error || !Array.isArray(data)) return [];
      return data;
    } catch {
      return [];
    }
  }

  function showLoading(text: string) {
    loadingText.textContent = text;
    loadingEl.classList.remove("hidden");
    resultsEl.classList.add("hidden");
  }

  function classifyChain(title: string): { emoji: string; chain: string; color: string } {
    const t = title.toLowerCase();
    if (t.includes("hard off") || t.includes("ハードオフ")) return { emoji: "📀", chain: "Hard Off", color: "bg-orange-100 text-orange-700 dark:bg-orange-950 dark:text-orange-400" };
    if (t.includes("book off") || t.includes("ブックオフ")) return { emoji: "📚", chain: "Book Off", color: "bg-blue-100 text-blue-700 dark:bg-blue-950 dark:text-blue-400" };
    if (t.includes("off house") || t.includes("オフハウス")) return { emoji: "🏠", chain: "Off House", color: "bg-green-100 text-green-700 dark:bg-green-950 dark:text-green-400" };
    if (t.includes("hobby off") || t.includes("ホビーオフ")) return { emoji: "🎯", chain: "Hobby Off", color: "bg-purple-100 text-purple-700 dark:bg-purple-950 dark:text-purple-400" };
    if (t.includes("mode off") || t.includes("モードオフ")) return { emoji: "👗", chain: "Mode Off", color: "bg-pink-100 text-pink-700 dark:bg-pink-950 dark:text-pink-400" };
    if (t.includes("treasure") || t.includes("トレジャー")) return { emoji: "💎", chain: "Treasure Factory", color: "bg-amber-100 text-amber-700 dark:bg-amber-950 dark:text-amber-400" };
    if (t.includes("2nd street") || t.includes("セカンド")) return { emoji: "🏪", chain: "2nd Street", color: "bg-teal-100 text-teal-700 dark:bg-teal-950 dark:text-teal-400" };
    if (t.includes("mandarake") || t.includes("まんだらけ")) return { emoji: "🎌", chain: "Mandarake", color: "bg-red-100 text-red-700 dark:bg-red-950 dark:text-red-400" };
    if (t.includes("suruga") || t.includes("駿河屋")) return { emoji: "🎮", chain: "Suruga-ya", color: "bg-indigo-100 text-indigo-700 dark:bg-indigo-950 dark:text-indigo-400" };
    if (t.includes("janpara") || t.includes("じゃんぱら")) return { emoji: "🔧", chain: "Janpara", color: "bg-gray-100 text-gray-700 dark:bg-gray-950 dark:text-gray-400" };
    if (t.includes("sofmap") || t.includes("ソフマップ")) return { emoji: "💻", chain: "Sofmap", color: "bg-sky-100 text-sky-700 dark:bg-sky-950 dark:text-sky-400" };
    return { emoji: "♻️", chain: "Tienda", color: "bg-zinc-100 text-zinc-600 dark:bg-zinc-800 dark:text-zinc-400" };
  }

  function renderResults(results: any[], locationLabel: string) {
    loadingEl.classList.add("hidden");

    if (results.length === 0) {
      resultsHeader.innerHTML = "";
      resultsList.innerHTML = `
        <div class="text-center py-8 text-zinc-400 dark:text-zinc-500">
          <p class="text-3xl mb-2">🔍</p>
          <p class="font-medium">No encontramos tiendas</p>
          <p class="text-sm mt-1">Prueba otra zona o categoría</p>
        </div>`;
      resultsEl.classList.remove("hidden");
      return;
    }

    // Sort by rating
    results.sort((a, b) => (b.rating || 0) - (a.rating || 0));

    resultsHeader.innerHTML = `
      <div class="bg-gradient-to-r from-emerald-500 to-teal-500 rounded-2xl px-4 py-3 text-center">
        <p class="text-white font-bold text-sm">${results.length} tiendas en ${locationLabel}</p>
        <p class="text-white/70 text-xs mt-0.5">Ordenadas por valoración</p>
      </div>`;

    let html = `<div class="bg-white dark:bg-zinc-900 rounded-2xl border border-zinc-100 dark:border-zinc-800 overflow-hidden shadow-sm">
      <ul class="divide-y divide-zinc-50 dark:divide-zinc-800/50">`;

    for (const r of results) {
      const chain = classifyChain(r.title);
      const link = r.place_id
        ? `https://maps.google.com/maps?q=place_id:${r.place_id}`
        : "#";
      const dirLink = r.place_id
        ? `https://www.google.com/maps/dir/?api=1&destination=${encodeURIComponent(r.title)}&destination_place_id=${r.place_id}`
        : null;
      const stars = r.rating ? `⭐ ${r.rating}` : "";
      const reviews = r.reviews ? `(${r.reviews})` : "";

      html += `
        <li class="px-4 py-3">
          <div class="flex items-start gap-2.5">
            <span class="text-xl mt-0.5 shrink-0">${chain.emoji}</span>
            <div class="flex-1 min-w-0">
              <div class="flex items-start justify-between gap-2">
                <div class="min-w-0">
                  <a href="${link}" target="_blank" rel="noopener noreferrer"
                     class="font-semibold text-sm text-zinc-800 dark:text-zinc-200 hover:text-emerald-600 dark:hover:text-emerald-400 transition-colors inline-flex items-center gap-1.5">
                    ${r.title}
                    <svg class="w-3 h-3 text-blue-500 shrink-0" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/></svg>
                  </a>
                </div>
                ${dirLink ? `<a href="${dirLink}" target="_blank" rel="noopener noreferrer" class="shrink-0 w-7 h-7 rounded-full flex items-center justify-center hover:bg-zinc-100 dark:hover:bg-zinc-800 transition-colors" title="Cómo llegar"><svg class="w-3.5 h-3.5 text-zinc-400 dark:text-zinc-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7" /></svg></a>` : ""}
              </div>
              <div class="flex flex-wrap items-center gap-1.5 mt-1">
                <span class="text-[0.65rem] font-bold px-1.5 py-0.5 rounded ${chain.color}">${chain.chain}</span>
                ${stars ? `<span class="text-[0.65rem] font-bold text-amber-600 dark:text-amber-400">${stars} ${reviews}</span>` : ""}
                ${r.price ? `<span class="text-[0.65rem] font-bold px-1.5 py-0.5 rounded bg-emerald-50 text-emerald-700 dark:bg-emerald-950 dark:text-emerald-400">${r.price}</span>` : ""}
              </div>
              ${r.address ? `<p class="text-[0.65rem] text-zinc-400 dark:text-zinc-500 mt-0.5 truncate">${r.address}</p>` : ""}
            </div>
          </div>
        </li>`;
    }

    html += `</ul></div>`;

    // Maps link
    const catLabel = activeCat === "all" ? "リサイクルショップ" : CAT_QUERIES[activeCat][0];
    let mapsUrl: string;
    if (userCoords) {
      mapsUrl = `https://www.google.com/maps/search/${encodeURIComponent(catLabel)}/@${userCoords.lat},${userCoords.lng},14z`;
    } else {
      mapsUrl = `https://www.google.com/maps/search/${encodeURIComponent(catLabel + " " + locationLabel + " Tokyo")}`;
    }

    html += `
      <a href="${mapsUrl}" target="_blank" rel="noopener noreferrer"
         class="flex items-center justify-center gap-2 bg-blue-500 text-white font-semibold px-6 py-3 rounded-xl shadow hover:bg-blue-600 transition text-sm">
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/></svg>
        Ver todas en Google Maps
      </a>`;

    resultsList.innerHTML = html;
    resultsEl.classList.remove("hidden");
    resultsEl.scrollIntoView({ behavior: "smooth", block: "start" });
  }
</script>
