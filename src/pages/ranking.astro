---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Ranking restaurantes" activeNav="discover">
  <main class="max-w-lg mx-auto px-4 py-6 space-y-6">
    <div class="text-center">
      <h1 class="text-2xl font-bold text-zinc-900 dark:text-white">🏆 Ranking</h1>
      <p class="text-sm text-zinc-500 dark:text-zinc-400 mt-1">
        Puntuad los restaurantes que probéis
      </p>
    </div>

    <!-- Add restaurant -->
    <div class="bg-white dark:bg-zinc-900 rounded-2xl border border-zinc-100 dark:border-zinc-800 p-4 shadow-sm space-y-3">
      <div class="relative">
        <input
          id="search-input"
          type="text"
          placeholder="Buscar restaurante..."
          autocomplete="off"
          class="w-full px-4 py-3 rounded-xl bg-zinc-50 dark:bg-zinc-800 border border-zinc-200 dark:border-zinc-700 text-zinc-900 dark:text-white placeholder-zinc-400 dark:placeholder-zinc-500 focus:outline-none focus:border-amber-500 transition-colors text-sm"
        />
        <div id="search-spinner" class="hidden absolute right-3 top-1/2 -translate-y-1/2">
          <div class="w-4 h-4 border-2 border-zinc-300 border-t-amber-500 rounded-full animate-spin"></div>
        </div>
      </div>

      <!-- Search results dropdown -->
      <div id="search-results" class="hidden rounded-xl bg-white dark:bg-zinc-800 border border-zinc-200 dark:border-zinc-700 overflow-hidden shadow-lg max-h-64 overflow-y-auto">
      </div>

      <!-- Selected restaurant -->
      <div id="selected-restaurant" class="hidden">
        <div class="bg-amber-50 dark:bg-amber-950/30 rounded-xl p-3 border border-amber-200 dark:border-amber-800">
          <div class="flex items-start justify-between gap-2">
            <div class="min-w-0">
              <p id="selected-name" class="font-semibold text-sm text-zinc-900 dark:text-white"></p>
              <p id="selected-address" class="text-xs text-zinc-500 dark:text-zinc-400 mt-0.5 truncate"></p>
              <div class="flex items-center gap-2 mt-1">
                <span id="selected-rating" class="text-xs font-bold text-amber-600 dark:text-amber-400"></span>
                <span id="selected-type" class="text-xs text-zinc-400"></span>
              </div>
            </div>
            <button id="clear-selected" class="shrink-0 w-6 h-6 rounded-full flex items-center justify-center hover:bg-zinc-200 dark:hover:bg-zinc-700 transition-colors text-zinc-400">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
            </button>
          </div>
        </div>

        <!-- Ratings -->
        <div class="grid grid-cols-2 gap-3 mt-3">
          <div class="space-y-1.5">
            <label class="text-xs font-bold text-zinc-500 dark:text-zinc-400 uppercase tracking-wider block text-center">Sergio</label>
            <div class="flex items-center justify-center gap-1">
              <button id="sergio-down" class="w-8 h-8 rounded-lg bg-zinc-100 dark:bg-zinc-800 flex items-center justify-center text-zinc-500 hover:bg-zinc-200 dark:hover:bg-zinc-700 active:scale-90 transition-all font-bold">−</button>
              <span id="sergio-score" class="w-10 text-center text-2xl font-black text-zinc-900 dark:text-white">5</span>
              <button id="sergio-up" class="w-8 h-8 rounded-lg bg-zinc-100 dark:bg-zinc-800 flex items-center justify-center text-zinc-500 hover:bg-zinc-200 dark:hover:bg-zinc-700 active:scale-90 transition-all font-bold">+</button>
            </div>
          </div>
          <div class="space-y-1.5">
            <label class="text-xs font-bold text-zinc-500 dark:text-zinc-400 uppercase tracking-wider block text-center">Ester</label>
            <div class="flex items-center justify-center gap-1">
              <button id="ester-down" class="w-8 h-8 rounded-lg bg-zinc-100 dark:bg-zinc-800 flex items-center justify-center text-zinc-500 hover:bg-zinc-200 dark:hover:bg-zinc-700 active:scale-90 transition-all font-bold">−</button>
              <span id="ester-score" class="w-10 text-center text-2xl font-black text-zinc-900 dark:text-white">5</span>
              <button id="ester-up" class="w-8 h-8 rounded-lg bg-zinc-100 dark:bg-zinc-800 flex items-center justify-center text-zinc-500 hover:bg-zinc-200 dark:hover:bg-zinc-700 active:scale-90 transition-all font-bold">+</button>
            </div>
          </div>
        </div>

        <button
          id="save-btn"
          class="w-full mt-3 bg-amber-500 hover:bg-amber-400 text-white font-bold py-3 rounded-xl text-sm active:scale-95 transition-all"
        >
          Guardar puntuación
        </button>
      </div>
    </div>

    <!-- Stats -->
    <div id="stats" class="hidden grid grid-cols-3 gap-2">
      <div class="bg-white dark:bg-zinc-900 rounded-xl border border-zinc-100 dark:border-zinc-800 p-3 text-center">
        <p id="stat-total" class="text-xl font-black text-zinc-900 dark:text-white">0</p>
        <p class="text-[0.65rem] text-zinc-400 font-semibold uppercase">Probados</p>
      </div>
      <div class="bg-white dark:bg-zinc-900 rounded-xl border border-zinc-100 dark:border-zinc-800 p-3 text-center">
        <p id="stat-sergio-avg" class="text-xl font-black text-blue-500">0</p>
        <p class="text-[0.65rem] text-zinc-400 font-semibold uppercase">Media S.</p>
      </div>
      <div class="bg-white dark:bg-zinc-900 rounded-xl border border-zinc-100 dark:border-zinc-800 p-3 text-center">
        <p id="stat-ester-avg" class="text-xl font-black text-pink-500">0</p>
        <p class="text-[0.65rem] text-zinc-400 font-semibold uppercase">Media E.</p>
      </div>
    </div>

    <!-- Ranking list -->
    <div id="ranking-list" class="space-y-2"></div>

    <!-- Empty state -->
    <div id="empty-state" class="text-center py-8 text-zinc-400 dark:text-zinc-500">
      <p class="text-4xl mb-2">🍽️</p>
      <p class="font-medium">Sin restaurantes aún</p>
      <p class="text-sm mt-1">Busca y puntúa el primero</p>
    </div>

    <!-- Back link -->
    <div class="text-center pt-2">
      <a href="/random" class="text-sm text-zinc-400 hover:text-zinc-600 dark:hover:text-zinc-300 transition-colors">
        ← Descubrir
      </a>
    </div>
  </main>
</Layout>

<script>
  interface RankedRestaurant {
    id: string;
    name: string;
    address?: string;
    type?: string;
    googleRating?: number;
    placeId?: string;
    sergio: number;
    ester: number;
    date: string;
  }

  const STORAGE_KEY = "tokyo26_ranking";
  const searchInput = document.getElementById("search-input") as HTMLInputElement;
  const searchSpinner = document.getElementById("search-spinner")!;
  const searchResults = document.getElementById("search-results")!;
  const selectedEl = document.getElementById("selected-restaurant")!;
  const selectedName = document.getElementById("selected-name")!;
  const selectedAddress = document.getElementById("selected-address")!;
  const selectedRating = document.getElementById("selected-rating")!;
  const selectedType = document.getElementById("selected-type")!;
  const clearBtn = document.getElementById("clear-selected")!;
  const sergioScore = document.getElementById("sergio-score")!;
  const esterScore = document.getElementById("ester-score")!;
  const saveBtn = document.getElementById("save-btn")!;
  const rankingList = document.getElementById("ranking-list")!;
  const emptyState = document.getElementById("empty-state")!;
  const statsEl = document.getElementById("stats")!;

  let selectedPlace: { name: string; address?: string; type?: string; rating?: number; placeId?: string } | null = null;
  let sergio = 5;
  let ester = 5;
  let searchTimeout: ReturnType<typeof setTimeout>;
  let editingId: string | null = null;

  // Load rankings
  function loadRankings(): RankedRestaurant[] {
    try {
      return JSON.parse(localStorage.getItem(STORAGE_KEY) || "[]");
    } catch { return []; }
  }

  function saveRankings(list: RankedRestaurant[]) {
    localStorage.setItem(STORAGE_KEY, JSON.stringify(list));
  }

  // Score controls
  function updateScore(who: "sergio" | "ester", delta: number) {
    if (who === "sergio") {
      sergio = Math.max(1, Math.min(10, sergio + delta));
      sergioScore.textContent = String(sergio);
    } else {
      ester = Math.max(1, Math.min(10, ester + delta));
      esterScore.textContent = String(ester);
    }
  }

  document.getElementById("sergio-up")!.addEventListener("click", () => updateScore("sergio", 1));
  document.getElementById("sergio-down")!.addEventListener("click", () => updateScore("sergio", -1));
  document.getElementById("ester-up")!.addEventListener("click", () => updateScore("ester", 1));
  document.getElementById("ester-down")!.addEventListener("click", () => updateScore("ester", -1));

  // Search
  searchInput.addEventListener("input", () => {
    clearTimeout(searchTimeout);
    const q = searchInput.value.trim();
    if (q.length < 2) {
      searchResults.classList.add("hidden");
      return;
    }
    searchSpinner.classList.remove("hidden");
    searchTimeout = setTimeout(() => doSearch(q), 400);
  });

  async function doSearch(query: string) {
    try {
      const res = await fetch(`/api/places?q=${encodeURIComponent(query + " restaurant Tokyo")}`);
      const data = await res.json();
      searchSpinner.classList.add("hidden");

      if (!Array.isArray(data) || data.length === 0) {
        searchResults.innerHTML = `<div class="px-4 py-3 text-sm text-zinc-400">Sin resultados</div>`;
        searchResults.classList.remove("hidden");
        return;
      }

      let html = "";
      for (const r of data) {
        const stars = r.rating ? `⭐ ${r.rating}` : "";
        const addr = r.address ? r.address.split(",").slice(0, 2).join(",") : "";
        html += `
          <button class="search-result w-full text-left px-4 py-3 hover:bg-zinc-50 dark:hover:bg-zinc-700/50 transition-colors border-b border-zinc-100 dark:border-zinc-700/50 last:border-0"
                  data-name="${(r.title || "").replace(/"/g, "&quot;")}"
                  data-address="${(r.address || "").replace(/"/g, "&quot;")}"
                  data-type="${(r.type || "").replace(/"/g, "&quot;")}"
                  data-rating="${r.rating || ""}"
                  data-place-id="${r.place_id || ""}">
            <p class="font-semibold text-sm text-zinc-800 dark:text-zinc-200">${r.title}</p>
            <div class="flex items-center gap-2 mt-0.5">
              ${stars ? `<span class="text-xs font-bold text-amber-600 dark:text-amber-400">${stars}</span>` : ""}
              ${r.type ? `<span class="text-xs text-zinc-400">${r.type}</span>` : ""}
            </div>
            ${addr ? `<p class="text-xs text-zinc-400 dark:text-zinc-500 mt-0.5 truncate">${addr}</p>` : ""}
          </button>`;
      }
      searchResults.innerHTML = html;
      searchResults.classList.remove("hidden");

      // Attach click handlers
      searchResults.querySelectorAll<HTMLButtonElement>(".search-result").forEach(btn => {
        btn.addEventListener("click", () => selectResult(btn));
      });
    } catch {
      searchSpinner.classList.add("hidden");
      searchResults.innerHTML = `<div class="px-4 py-3 text-sm text-red-400">Error al buscar</div>`;
      searchResults.classList.remove("hidden");
    }
  }

  function selectResult(btn: HTMLButtonElement) {
    selectedPlace = {
      name: btn.dataset.name || "",
      address: btn.dataset.address || undefined,
      type: btn.dataset.type || undefined,
      rating: btn.dataset.rating ? parseFloat(btn.dataset.rating) : undefined,
      placeId: btn.dataset.placeId || undefined,
    };

    selectedName.textContent = selectedPlace.name;
    selectedAddress.textContent = selectedPlace.address || "";
    selectedRating.textContent = selectedPlace.rating ? `⭐ ${selectedPlace.rating}` : "";
    selectedType.textContent = selectedPlace.type || "";

    searchResults.classList.add("hidden");
    searchInput.value = "";
    selectedEl.classList.remove("hidden");

    // Reset scores if not editing
    if (!editingId) {
      sergio = 5;
      ester = 5;
      sergioScore.textContent = "5";
      esterScore.textContent = "5";
    }
  }

  // Clear selection
  clearBtn.addEventListener("click", () => {
    selectedPlace = null;
    editingId = null;
    selectedEl.classList.add("hidden");
    saveBtn.textContent = "Guardar puntuación";
  });

  // Save
  saveBtn.addEventListener("click", () => {
    if (!selectedPlace) return;

    const rankings = loadRankings();

    if (editingId) {
      const idx = rankings.findIndex(r => r.id === editingId);
      if (idx !== -1) {
        rankings[idx].sergio = sergio;
        rankings[idx].ester = ester;
        rankings[idx].name = selectedPlace.name;
        rankings[idx].address = selectedPlace.address;
        rankings[idx].type = selectedPlace.type;
        rankings[idx].googleRating = selectedPlace.rating;
        rankings[idx].placeId = selectedPlace.placeId;
      }
      editingId = null;
      saveBtn.textContent = "Guardar puntuación";
    } else {
      const entry: RankedRestaurant = {
        id: Date.now().toString(36) + Math.random().toString(36).slice(2, 6),
        name: selectedPlace.name,
        address: selectedPlace.address,
        type: selectedPlace.type,
        googleRating: selectedPlace.rating,
        placeId: selectedPlace.placeId,
        sergio,
        ester,
        date: new Date().toISOString().slice(0, 10),
      };
      rankings.push(entry);
    }

    saveRankings(rankings);
    selectedPlace = null;
    selectedEl.classList.add("hidden");
    renderRankings();

    // Flash effect
    saveBtn.textContent = "✓ Guardado";
    setTimeout(() => { saveBtn.textContent = "Guardar puntuación"; }, 1000);
  });

  // Render
  function getMedal(pos: number): string {
    if (pos === 0) return "🥇";
    if (pos === 1) return "🥈";
    if (pos === 2) return "🥉";
    return `<span class="text-xs font-bold text-zinc-400">#${pos + 1}</span>`;
  }

  function renderRankings() {
    const rankings = loadRankings();

    if (rankings.length === 0) {
      emptyState.classList.remove("hidden");
      statsEl.classList.add("hidden");
      rankingList.innerHTML = "";
      return;
    }

    emptyState.classList.add("hidden");
    statsEl.classList.remove("hidden");

    // Stats
    document.getElementById("stat-total")!.textContent = String(rankings.length);
    const avgS = rankings.reduce((s, r) => s + r.sergio, 0) / rankings.length;
    const avgE = rankings.reduce((s, r) => s + r.ester, 0) / rankings.length;
    document.getElementById("stat-sergio-avg")!.textContent = avgS.toFixed(1);
    document.getElementById("stat-ester-avg")!.textContent = avgE.toFixed(1);

    // Sort by average desc
    const sorted = [...rankings].sort((a, b) => {
      const avgA = (a.sergio + a.ester) / 2;
      const avgB = (b.sergio + b.ester) / 2;
      return avgB - avgA;
    });

    let html = "";
    sorted.forEach((r, i) => {
      const avg = ((r.sergio + r.ester) / 2).toFixed(1);
      const medal = getMedal(i);
      const link = r.placeId
        ? `https://maps.google.com/maps?q=place_id:${r.placeId}`
        : null;
      const dirLink = r.placeId
        ? `https://www.google.com/maps/dir/?api=1&destination=${encodeURIComponent(r.name)}&destination_place_id=${r.placeId}`
        : null;

      const isTop3 = i < 3;
      const borderClass = isTop3 ? "border-amber-200 dark:border-amber-800" : "border-zinc-100 dark:border-zinc-800";
      const bgClass = isTop3 ? "bg-amber-50/50 dark:bg-amber-950/20" : "bg-white dark:bg-zinc-900";

      html += `
        <div class="${bgClass} rounded-2xl border ${borderClass} p-4 shadow-sm">
          <div class="flex items-start gap-3">
            <div class="shrink-0 w-8 text-center mt-0.5">${medal}</div>
            <div class="flex-1 min-w-0">
              <div class="flex items-start justify-between gap-2">
                <div class="min-w-0">
                  ${link
                    ? `<a href="${link}" target="_blank" rel="noopener noreferrer" class="font-bold text-sm text-zinc-900 dark:text-white hover:text-amber-600 dark:hover:text-amber-400 transition-colors inline-flex items-center gap-1">
                        ${r.name}
                        <svg class="w-3 h-3 text-blue-500 shrink-0" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/></svg>
                      </a>`
                    : `<p class="font-bold text-sm text-zinc-900 dark:text-white">${r.name}</p>`
                  }
                  <div class="flex items-center gap-2 mt-0.5">
                    ${r.type ? `<span class="text-[0.65rem] text-zinc-400">${r.type}</span>` : ""}
                    ${r.date ? `<span class="text-[0.65rem] text-zinc-300 dark:text-zinc-600">${r.date}</span>` : ""}
                  </div>
                </div>
                <div class="text-right shrink-0">
                  <p class="text-lg font-black ${isTop3 ? "text-amber-500" : "text-zinc-700 dark:text-zinc-300"}">${avg}</p>
                  <p class="text-[0.6rem] text-zinc-400 uppercase font-semibold">media</p>
                </div>
              </div>

              <!-- Individual scores -->
              <div class="flex items-center gap-4 mt-2">
                <div class="flex items-center gap-1.5">
                  <span class="text-[0.65rem] font-bold text-blue-500 uppercase">S:</span>
                  <div class="flex gap-px">
                    ${Array.from({length: 10}, (_, n) => `<div class="w-2 h-2 rounded-sm ${n < r.sergio ? "bg-blue-500" : "bg-zinc-200 dark:bg-zinc-700"}"></div>`).join("")}
                  </div>
                  <span class="text-xs font-bold text-blue-600 dark:text-blue-400">${r.sergio}</span>
                </div>
                <div class="flex items-center gap-1.5">
                  <span class="text-[0.65rem] font-bold text-pink-500 uppercase">E:</span>
                  <div class="flex gap-px">
                    ${Array.from({length: 10}, (_, n) => `<div class="w-2 h-2 rounded-sm ${n < r.ester ? "bg-pink-500" : "bg-zinc-200 dark:bg-zinc-700"}"></div>`).join("")}
                  </div>
                  <span class="text-xs font-bold text-pink-600 dark:text-pink-400">${r.ester}</span>
                </div>
              </div>

              <!-- Actions -->
              <div class="flex items-center gap-2 mt-2">
                ${dirLink ? `<a href="${dirLink}" target="_blank" rel="noopener noreferrer" class="text-[0.65rem] font-semibold text-zinc-400 hover:text-blue-500 transition-colors flex items-center gap-1">
                  <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7" /></svg>
                  Ir
                </a>` : ""}
                <button class="edit-btn text-[0.65rem] font-semibold text-zinc-400 hover:text-amber-500 transition-colors" data-id="${r.id}">Editar</button>
                <button class="delete-btn text-[0.65rem] font-semibold text-zinc-400 hover:text-red-500 transition-colors" data-id="${r.id}">Borrar</button>
              </div>
            </div>
          </div>
        </div>`;
    });

    rankingList.innerHTML = html;

    // Attach edit/delete handlers
    rankingList.querySelectorAll<HTMLButtonElement>(".edit-btn").forEach(btn => {
      btn.addEventListener("click", () => editEntry(btn.dataset.id!));
    });
    rankingList.querySelectorAll<HTMLButtonElement>(".delete-btn").forEach(btn => {
      btn.addEventListener("click", () => deleteEntry(btn.dataset.id!));
    });
  }

  function editEntry(id: string) {
    const rankings = loadRankings();
    const entry = rankings.find(r => r.id === id);
    if (!entry) return;

    editingId = id;
    selectedPlace = {
      name: entry.name,
      address: entry.address,
      type: entry.type,
      rating: entry.googleRating,
      placeId: entry.placeId,
    };

    selectedName.textContent = entry.name;
    selectedAddress.textContent = entry.address || "";
    selectedRating.textContent = entry.googleRating ? `⭐ ${entry.googleRating}` : "";
    selectedType.textContent = entry.type || "";

    sergio = entry.sergio;
    ester = entry.ester;
    sergioScore.textContent = String(sergio);
    esterScore.textContent = String(ester);

    selectedEl.classList.remove("hidden");
    saveBtn.textContent = "Actualizar puntuación";
    window.scrollTo({ top: 0, behavior: "smooth" });
  }

  function deleteEntry(id: string) {
    const rankings = loadRankings();
    const entry = rankings.find(r => r.id === id);
    if (!entry) return;
    if (!confirm(`¿Borrar ${entry.name}?`)) return;

    saveRankings(rankings.filter(r => r.id !== id));
    renderRankings();
  }

  // Init
  renderRankings();
</script>
